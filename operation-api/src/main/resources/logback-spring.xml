<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <timestamp key="BY_DATE" datePattern="yyyy-MM-dd"/>
    <property name="LOG_CONSOLE_PATTERN" value="[%d{yyyy-MM-dd HH:mm:ss}:%-4relative] %green([%thread]) %highlight(%-5level) %boldWhite([%C.%M:%yellow(%L)]) - %msg%n"/>
    <property name="LOG_FILE_PATTERN" value="[%d{yyyy-MM-dd HH:mm:ss}:%-4relative] [%thread] %-5level [%C.%M:%L] - %msg%n"/>
    <!-- Lambda 간결한 로그 패턴 (색상 코드 제거 → CloudWatch에서 불필요) -->
    <property name="LOG_LAMBDA_PATTERN" value="[%d{yyyy-MM-dd HH:mm:ss}] %-5level [%C{0}.%M:%L] - %msg%n"/>

    <!-- ==================== Lambda 환경 ==================== -->
    <!-- CloudWatch 자동 전송 → Ingestion 비용 최소화를 위해 WARN 레벨 -->
    <springProfile name="lambda-dev | lambda-prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_LAMBDA_PATTERN}</pattern>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ==================== 로컬/테스트 환경 ==================== -->
    <springProfile name="local | test">
        <include resource="console-appender.xml"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ==================== EC2 Prod 환경 ==================== -->
    <springProfile name="prod">
        <include resource="file-info-appender.xml"/>
        <include resource="file-error-appender.xml"/>
        <root level="INFO">
            <appender-ref ref="FILE-INFO"/>
            <appender-ref ref="FILE-ERROR"/>
        </root>
    </springProfile>
</configuration>
